; AegisCore agent sandbox profile
; Generated at spawn time - do not edit manually.
(version 1)
(deny default)

; Core execution
(allow process-exec
  (subpath "/usr/bin")
  (subpath "/usr/local/bin")
  (subpath "/opt/homebrew/bin")
  (subpath "/opt/homebrew/Cellar")
  (subpath "/bin")
  (subpath "/usr/sbin")
  ; User-installed AI CLI tools and their runtimes
  (subpath "@@HOME@@/.claude")
  (subpath "@@HOME@@/.nvm")
  (subpath "@@HOME@@/.local/bin"))
@@EXTRA_EXEC_PATHS@@
(allow process-fork)
(allow signal)
; sysctl-read is required by the claude binary for platform/hardware detection at startup.
; Without it, sandbox-exec sends SIGTRAP and the process dies immediately.
(allow sysctl-read)
(allow mach-lookup)
(allow iokit-get-properties)

; Broad read access — agents need to read freely to understand project context,
; run bash commands, load system libraries, and use provider auth state.
; Writes are still tightly restricted.
(allow file-read* (subpath "/"))

; Restricted write access: worktree + shared temp space only
(allow file-read* file-write*
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/var/folders")
  (subpath "/dev/null")
  (subpath "/dev/zero")
  (subpath "/dev/ttys"))

; Agent worktree
(allow file-read* file-write*
  (subpath "@@WORKTREE_PATH@@"))

; Extra reads
@@EXTRA_READS@@

; Extra writes
@@EXTRA_WRITES@@

; Network policy
@@NETWORK_POLICY@@
