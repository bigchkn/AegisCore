; AegisCore agent sandbox profile
; Generated at spawn time - do not edit manually.
(version 1)
(deny default)

; Core execution
(allow process-exec
  (subpath "/usr/bin")
  (subpath "/usr/local/bin")
  (subpath "/opt/homebrew/bin")
  (subpath "/opt/homebrew/Cellar")
  (subpath "/bin")
  (subpath "/usr/sbin")
  ; User-installed AI CLI tools and their runtimes
  (subpath "@@HOME@@/.claude")
  (subpath "@@HOME@@/.nvm")
  (subpath "@@HOME@@/.local/bin"))
@@EXTRA_EXEC_PATHS@@
(allow process-fork)
(allow signal)

; Hard denials — must appear before the broad file-read allow (first-match wins in Seatbelt).
; These protect credentials even though (allow file-read* /) comes after.
(deny file-read*
  (subpath "@@HOME@@/.ssh")
  (subpath "@@HOME@@/.aws")
  (subpath "@@HOME@@/.gnupg")
  (subpath "@@HOME@@/.config/1Password")
  (subpath "@@HOME@@/Library/Keychains"))

(deny file-read*
  (subpath "@@AEGIS_LOGS_DIR@@"))

@@HARD_DENY_READS@@

; Broad read access — agents need to read freely to understand project context,
; run bash commands, and load system libraries. Writes are still tightly restricted.
(allow file-read* (subpath "/"))

; Restricted write access: worktree + shared temp space only
(allow file-read* file-write*
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/var/folders"))

; Agent worktree
(allow file-read* file-write*
  (subpath "@@WORKTREE_PATH@@"))

; Extra reads
@@EXTRA_READS@@

; Extra writes
@@EXTRA_WRITES@@

; Network policy
@@NETWORK_POLICY@@
