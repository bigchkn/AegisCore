; AegisCore agent sandbox profile
; Generated at spawn time - do not edit manually.
(version 1)
(allow default)

; Global write restriction
(deny file-write*
  (subpath "/"))

; Core temporary and device writes
(allow file-write*
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/var/folders")
  (subpath "/private/var/folders")
  (subpath "/dev"))

; Whitelist read/write for specific operational areas
(allow file-read* file-write*
  (subpath "@@WORKTREE_PATH@@")
  (subpath "@@AEGIS_LOGS_DIR@@"))

; User-specific whitelists for tool persistence (e.g. Claude Code)
(allow file-read* file-write*
  (subpath "@@HOME@@/.claude")
  (literal "@@HOME@@/.claude.json")
  (literal "@@HOME@@/.claude.json.lock")
  (regex #"^@@HOME@@/\.claude\.json\.tmp")
  (subpath "@@HOME@@/Library/Caches/claude-cli-nodejs"))

; Extra reads (though largely redundant with allow default)
@@EXTRA_READS@@

; Extra writes
@@EXTRA_WRITES@@

; Network policy (carve out from allow default)
@@NETWORK_POLICY@@
